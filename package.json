{
  "name": "antigram",
  "version": "1.0.0",
  "description": "A powerful Telegram bot that bridges directly into your local IDE/Browser automation agent, enabling remote code execution, voice commands, file management, and proactive progress notifications from anywhere.",
  "main": "index.js",
  "scripts": {
    "setup": "node setup.js",
    "setup:reconfigure": "node setup.js --reconfigure",
    "start": "export CHROME_PATH=\"${CHROME_PATH:-/usr/bin/google-chrome}\"; \"$CHROME_PATH\" --remote-debugging-port=9222 --remote-allow-origins='*' --remote-debugging-address=0.0.0.0 --no-sandbox & node index.js",
    "start:mac": "\"/Applications/Antigravity.app/Contents/MacOS/Electron\" --remote-debugging-port=9222 --remote-allow-origins=\"*\" --remote-debugging-address=0.0.0.0 & node index.js",
    "start:linux": "export ANTIGRAVITY_PATH=\"${ANTIGRAVITY_PATH:-/usr/bin/antigravity}\"; \"$ANTIGRAVITY_PATH\" --remote-debugging-port=9222 --remote-allow-origins='*' --remote-debugging-address=0.0.0.0 --no-sandbox & node index.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "telegram",
    "bot",
    "ide",
    "automation",
    "puppeteer",
    "remote",
    "agent"
  ],
  "author": "Antigram Contributors",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "puppeteer-core": "^24.39.0",
    "telegraf": "^4.16.3"
  }
}