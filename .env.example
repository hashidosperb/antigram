# Telegram Bot Configuration
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated list of numeric Telegram User IDs authorized to command the bot
# You can get your User ID from bots like @userinfobot
TELEGRAM_USER_ID=123456789,987654321

# Browser Remote Debugging Port (Must match the IDE/Browser's launch flag)
CDP_PORT=9222

# Absolute path to the IDE executable used by the /new command
ANTIGRAVITY_PATH=/usr/bin/antigravity